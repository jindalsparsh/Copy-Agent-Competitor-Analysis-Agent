# ─────────────────────────────────────────────
# Anthropic
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=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

# Claude model to use (default: claude-opus-4-6)
CLAUDE_MODEL=claude-opus-4-6
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.3

# ─────────────────────────────────────────────
# Google – Service Account
# Path to your service account JSON key file.
# In Docker, mount it as a read-only volume and
# point this env var at the container path.
# ─────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=/secrets/service_account.json

# ─────────────────────────────────────────────
# Google Workspace IDs
# ─────────────────────────────────────────────
# The spreadsheet ID from the URL:
# https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID= 1TdnV-qo885H-9RVPI0hiro7tx7Yyu1trzmaiplLpTIQ

# The A1 range to read (headers + data rows)
GOOGLE_SHEET_RANGE=Sheet1!A1:Z1000

# Google Drive file ID of the brand/style reference document
# Supports: PDF, RTF, TXT, or a Google Doc (auto-exported to PDF)
GOOGLE_DRIVE_FILE_ID=1uDLaYeeEElU5fRXlYy7O-wqp6sP7F1Mp

# Google Doc ID where generated copy will be appended
GOOGLE_DOC_ID=1vi0GNhLoltw3p__ZOfMuEOYwKwycwPEgZHrMfA8LFWE

# ─────────────────────────────────────────────
# Pipeline Behavior
# ─────────────────────────────────────────────
# Only process rows where the 'status' column matches this value (case-insensitive)
PROCESS_STATUS_FILTER=READY

# Whether to update row status in the sheet after successful copy generation
UPDATE_SHEET_STATUS=true

# Value to write into the status cell after a row is processed
PROCESSED_STATUS_VALUE=DONE

# ─────────────────────────────────────────────
# Scheduling (APScheduler)
# ─────────────────────────────────────────────
# Set to true to enable the internal cron scheduler at startup
ENABLE_SCHEDULER=false

# Standard 5-field cron expression (minute hour day month weekday)
# Default: weekdays at 08:00
SCHEDULE_CRON=0 8 * * 1-5

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
LOG_LEVEL=INFO
PORT=8000
